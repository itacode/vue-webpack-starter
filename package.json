{
  "name": "vue-webpack-starter",
  "version": "1.0.0",
  "description": "Easily add vue to an existing page.",
  "main": "src/app/main.ts",
  "scripts": {
    "dev": "webpack serve --config-node-env development --mode=development --env platform=development --progress",
    "build": "webpack --config-node-env production --mode=production --env platform=production --progress",
